# ── MATM Root Environment ──────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Lines starting with # are comments — do not quote string values.

APP_ENV=dev
DEBUG=true

# PostgreSQL — must match the postgres service credentials in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://matm:matm@localhost:5432/matm

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# LLM — point to your Ollama instance or any OpenAI-compatible endpoint
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_DEFAULT_MODEL=qwen2.5:7b

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Public health data feeds
WHO_RSS_URL=https://www.who.int/rss-feeds/news-english.xml
PROMED_URL=https://promedmail.org/feed/

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
